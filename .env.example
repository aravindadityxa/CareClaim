# CareClaim - Environment Configuration Template
# Copy this file to .env and fill in with your actual configuration values
# IMPORTANT: Never commit the actual .env file to version control

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment: dev, staging, or prod
ENVIRONMENT=development

# Enable debug mode (false in production)
DEBUG=true

# Application name
APP_NAME=CareClaim

# ============================================================================
# DATABASE - POSTGRESQL (Primary Database)
# ============================================================================

# PostgreSQL connection parameters
# These define the connection to your PostgreSQL database for structured data
POSTGRES_USER=careclaim_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_SERVER=localhost
POSTGRES_DB=careclaim
POSTGRES_PORT=5432

# Optional: PostgreSQL SSL mode (disable, allow, prefer, require)
POSTGRES_SSLMODE=disable

# ============================================================================
# DATABASE - MONGODB (Document Storage)
# ============================================================================

# MongoDB connection URI for document storage
# Format: mongodb://[username:password@]host:port/database
# If MongoDB is unavailable, the system continues with limited functionality
MONGO_URI=mongodb://localhost:27017/careclaim

# Optional: MongoDB timeout in milliseconds
MONGO_SERVER_SELECTION_TIMEOUT=5000

# ============================================================================
# CACHE - REDIS
# ============================================================================

# Redis connection URL for caching and task queues
# Format: redis://[:password@]host:port/database
# If Redis is unavailable, caching is disabled (system still works)
REDIS_URL=redis://localhost:6379/0

# Optional: Redis timeout in seconds
REDIS_SOCKET_TIMEOUT=5

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret Key for token generation
# IMPORTANT: Must be a long, random, secure string in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-very-long-secret-key-change-this-in-production-use-at-least-32-characters

# JWT algorithm for token signing
JWT_ALGORITHM=HS256

# Token expiration time in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Optional: Refresh token expiration in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins - comma-separated list of allowed origins
# Must include your frontend URL
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ============================================================================
# OCR CONFIGURATION
# ============================================================================

# OCR service configuration for document text extraction
# Confidence threshold: 0.0-1.0 (recommended: 0.65-0.75)
OCR_CONFIDENCE_THRESHOLD=0.70

# OCR service endpoint (internal service URL)
OCR_SERVICE_URL=http://127.0.0.1:5001/ocr

# OCR processing timeout in seconds
OCR_SERVICE_TIMEOUT=120

# OCR engine: tesseract or easyocr
OCR_ENGINE=tesseract

# Optional: Tesseract path (if not in system PATH)
TESSERACT_PATH=/usr/bin/tesseract

# ============================================================================
# CLAIM PROCESSING & SCORING
# ============================================================================

# Auto-approval threshold (claims with score >= this are auto-approved)
# Recommended: 80-90
SCORE_AUTO_APPROVE_THRESHOLD=85

# Human review minimum threshold (claims below this are auto-denied)
# Recommended: 50-65
SCORE_HUMAN_REVIEW_MIN_THRESHOLD=60

# Appeal window duration in days
APPEAL_WINDOW_DAYS=30

# Maximum claim amount for auto-approval (in dollars)
# Claims over this amount require human review regardless of score
MAX_AUTO_APPROVE_AMOUNT=10000

# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================

# Email service settings for claim status notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@careclaim.com
SMTP_FROM_NAME=CareClaim Platform

# Enable/disable email notifications
SEND_EMAIL_NOTIFICATIONS=false

# ============================================================================
# AWS CONFIGURATION (Optional - for S3 document storage)
# ============================================================================

# AWS region for S3 bucket
AWS_REGION=us-east-1

# AWS access credentials
# Create IAM user with S3 permissions
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 bucket name for document storage (optional backup)
AWS_S3_BUCKET_NAME=careclaim-documents

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=logs/careclaim.log

# Maximum log file size in MB before rotation
LOG_MAX_SIZE=100

# Number of backup log files to keep
LOG_BACKUP_COUNT=10

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================

# Enable/disable specific features
ENABLE_FRAUD_DETECTION=true
ENABLE_MEDICAL_NECESSITY_CHECK=true
ENABLE_AUTO_APPROVAL=true
ENABLE_APPEALS=true
ENABLE_BATCH_PROCESSING=false

# ============================================================================
# PERFORMANCE & RATE LIMITING
# ============================================================================

# Maximum concurrent claim processing tasks
MAX_CONCURRENT_CLAIMS=10

# API rate limit: requests per minute per user
RATE_LIMIT_RPM=60

# Request timeout in seconds
REQUEST_TIMEOUT=30

# ============================================================================
# DEVELOPMENT SETTINGS (Development Only)
# ============================================================================

# These settings should NEVER be enabled in production

# Allow test data creation endpoint (dev only)
ALLOW_TEST_DATA_CREATION=true

# Skip authentication for testing (dev only)
SKIP_AUTH=false

# Verbose API logging
VERBOSE_LOGGING=false

# ============================================================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================================================

# Sentry error tracking (optional)
SENTRY_DSN=

# Application Performance Monitoring
APM_ENABLED=false

# ============================================================================
# NOTES
# ============================================================================

# For production deployment:
# 1. Use strong, randomly generated JWT_SECRET_KEY
# 2. Set ENVIRONMENT=production
# 3. Set DEBUG=false
# 4. Configure proper database with strong passwords
# 5. Set up SSL/TLS certificates
# 6. Configure email service for notifications
# 7. Set up monitoring and alerting
# 8. Enable request logging for audit trails
# 9. Configure automated backups
#
# For development:
# 1. Use the defaults provided
# 2. Create local PostgreSQL database
# 3. MongoDB and Redis are optional (system works without them)
# 4. Use demo credentials in API docs for testing
#
# To generate secure random values:
# JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DB Password: python -c "import secrets; print(secrets.token_urlsafe(16))"
